SWITCHYARD_ENV=development
SWITCHYARD_LOG_LEVEL=INFO
SWITCHYARD_SERVICE_NAME=switchyard-gateway
SWITCHYARD_OTEL_ENABLED=false
SWITCHYARD_METRICS_ENABLED=true
SWITCHYARD_METRICS_PATH=/metrics
SWITCHYARD_GATEWAY_HOST=127.0.0.1
SWITCHYARD_GATEWAY_PORT=8000
SWITCHYARD_DEFAULT_ROUTING_POLICY=balanced
SWITCHYARD_BENCHMARK_OUTPUT_DIR=artifacts/benchmarks
SWITCHYARD_DEFAULT_MODEL_ALIAS=
SWITCHYARD_LOCAL_MODELS=[]
SWITCHYARD_PHASE4={"admission_control":{"enabled":false,"global_concurrency_cap":64,"global_queue_size":128,"default_concurrency_cap":1,"default_queue_size":0,"request_timeout_seconds":30.0,"queue_timeout_seconds":5.0,"per_tenant_limits":[]},"circuit_breakers":{"enabled":false,"failure_threshold":5,"recovery_success_threshold":1,"open_cooldown_seconds":30.0,"request_timeout_seconds":30.0},"session_affinity":{"enabled":false,"ttl_seconds":300.0,"max_sessions":10000},"canary_routing":{"enabled":false,"default_percentage":0.0,"policies":[]},"shadow_routing":{"enabled":false,"default_sampling_rate":0.0,"policies":[]}}

# Example local model config:
# SWITCHYARD_DEFAULT_MODEL_ALIAS=qwen2.5-3b-instruct
# SWITCHYARD_LOCAL_MODELS=[{"alias":"qwen2.5-3b-instruct","model_identifier":"mlx-community/Qwen2.5-3B-Instruct-4bit","backend_type":"mlx_lm","generation_defaults":{"max_output_tokens":256,"temperature":0.2,"top_p":1.0},"warmup":{"enabled":true,"eager":false,"timeout_seconds":30}}]
#
# MLX-only alias:
# SWITCHYARD_DEFAULT_MODEL_ALIAS=chat-mlx
# SWITCHYARD_LOCAL_MODELS=[{"alias":"chat-mlx","model_identifier":"mlx-community/Qwen2.5-3B-Instruct-4bit","backend_type":"mlx_lm","generation_defaults":{"max_output_tokens":256,"temperature":0.2,"top_p":1.0},"warmup":{"enabled":true,"eager":false,"timeout_seconds":30}}]
#
# vLLM-Metal-only alias:
# SWITCHYARD_DEFAULT_MODEL_ALIAS=chat-metal
# SWITCHYARD_LOCAL_MODELS=[{"alias":"chat-metal","model_identifier":"NousResearch/Meta-Llama-3-8B-Instruct","backend_type":"vllm_metal","generation_defaults":{"max_output_tokens":256,"temperature":0.2,"top_p":1.0},"warmup":{"enabled":true,"eager":false,"timeout_seconds":30}}]
#
# Dual-backend alias sharing one serving target:
# SWITCHYARD_DEFAULT_MODEL_ALIAS=chat-shared
# SWITCHYARD_LOCAL_MODELS=[{"alias":"chat-mlx","serving_target":"chat-shared","model_identifier":"mlx-community/Qwen2.5-3B-Instruct-4bit","backend_type":"mlx_lm","configured_priority":80,"configured_weight":1.2,"generation_defaults":{"max_output_tokens":256,"temperature":0.2,"top_p":1.0},"warmup":{"enabled":true,"eager":false,"timeout_seconds":30}},{"alias":"chat-metal","serving_target":"chat-shared","model_identifier":"NousResearch/Meta-Llama-3-8B-Instruct","backend_type":"vllm_metal","configured_priority":100,"configured_weight":1.0,"generation_defaults":{"max_output_tokens":256,"temperature":0.2,"top_p":1.0},"warmup":{"enabled":true,"eager":false,"timeout_seconds":30}}]
#
# Example Phase 4 control-plane config:
# SWITCHYARD_PHASE4={"admission_control":{"enabled":true,"global_concurrency_cap":32,"global_queue_size":64,"default_concurrency_cap":8,"default_queue_size":16,"request_timeout_seconds":20.0,"queue_timeout_seconds":3.0,"per_tenant_limits":[{"tenant_id":"tenant-a","concurrency_cap":4,"queue_size":2}]},"circuit_breakers":{"enabled":true,"failure_threshold":3,"recovery_success_threshold":1,"open_cooldown_seconds":15.0,"request_timeout_seconds":20.0},"session_affinity":{"enabled":true,"ttl_seconds":120.0,"max_sessions":5000},"canary_routing":{"enabled":true,"default_percentage":5.0,"policies":[{"policy_name":"chat-rollout","serving_target":"chat-shared","enabled":true,"baseline_backend":"mlx-lm:chat-mlx","allocations":[{"backend_name":"vllm-metal:chat-metal","percentage":5.0}]}]},"shadow_routing":{"enabled":true,"default_sampling_rate":0.1,"policies":[{"policy_name":"chat-shadow","enabled":true,"target_backend":"vllm-metal:chat-metal","sampling_rate":0.1}]}}
